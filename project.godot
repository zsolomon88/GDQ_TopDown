config_version=5

[application]

config/name="M09. Top Down Movement (Workbook)"
run/main_scene="uid://c62bk8cggi6yq"
config/features=PackedStringArray("4.7")
run/max_fps=60
config/icon="res://icon_top_down_movement.png"

[autoload]

